{
  "name": "mini-claude-code",
  "version": "0.1.0",
  "description": "A minimal Claude Code-like CLI tool",
  "type": "module",
  "bin": {
    "mcc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --loader ts-node/esm src/index.ts",
    "dev": "npx tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "glob": "^11.0.1",
    "marked": "^15.0.0",
    "marked-terminal": "^7.3.0",
    "openai": "^4.78.0"
  },
  "optionalDependencies": {
    "playwright-core": "^1.50.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  }
}
